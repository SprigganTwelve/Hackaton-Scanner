// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init



generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}


datasource db {
  provider = "mysql"
}



model Account {
  id           Int      @id @default(autoincrement())
  name         String?  @db.VarChar(250)
  email        String?  @db.VarChar(250)
  password     String?  @db.VarChar(255)
  git_url      String?  @db.VarChar(350)
  access_token String?  @db.VarChar(250)

  projets      Project[]
}


model Project {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(250)
  created_at DateTime? 
  url        String   @db.VarChar(250)
  account_id Int

  account          Account @relation(fields: [account_id], references: [id])
  analysis_records AnalysisRecord[]
}


model AnalysisRecord {
  id         Int      @id @default(autoincrement())
  started_at DateTime
  status     String   @db.VarChar(50)
  project_id Int

  project  Project @relation(fields: [project_id], references: [id])
  reports  Report[]
  findings Finding[]
}


model Report {
  id          Int      @id @default(autoincrement())
  format      String?  @db.VarChar(50)
  created_at  DateTime?
  path        String   @db.VarChar(250)
  original_name String @db.VarChar(250)
  analysis_id Int?     @unique

  analysis AnalysisRecord? @relation(fields: [analysis_id], references: [id])
}


model Finding {
  id                 Int      @id @default(autoincrement())
  score              Decimal  @db.Decimal(15,2)
  filename           String   @db.VarChar(250)
  analysis_record_id Int

  analysis_record AnalysisRecord @relation(fields: [analysis_record_id], references: [id])
  line_infos      LineInfo[]
  solution        Solution?
}


model LineInfo {
  id         Int     @id @default(autoincrement())
  start_index Int
  end_index   Int
  finding_id Int

  finding Finding @relation(fields: [finding_id], references: [id])
}


model Solution {
  id               Int     @id @default(autoincrement())
  status           String  @db.VarChar(50)
  corrective_measure String?
  finding_id       Int     @unique

  finding Finding @relation(fields: [finding_id], references: [id])
}